      "name": "Patients",
      "item": [
        {
          "name": "Create patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Has ID', () => pm.expect(pm.response.json().id).to.be.a('number'));",
                  "pm.test('Status is TREATMENT', () => pm.expect(pm.response.json().status).to.eql('TREATMENT'));",
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('patientId', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/patients",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Тестов Иван Петрович\",\n  \"birthDate\": \"1985-04-12\",\n  \"gender\": \"MALE\",\n  \"snils\": \"777-888-999 00\",\n  \"phone\": \"+7-900-123-4567\",\n  \"address\": \"г. Москва, ул. Тестовая, д. 1\"\n}"
            }
          }
        },
        {
          "name": "Get patient by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Has fullName', () => pm.expect(pm.response.json().fullName).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/patients/{{patientId}}"
          }
        },
        {
          "name": "Get all patients (paginated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Has content array', () => pm.expect(pm.response.json().content).to.be.an('array'));",
                  "pm.test('Has pagination fields', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.page).to.be.a('number');",
                  "  pm.expect(body.totalElements).to.be.a('number');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/patients?page=0&size=10",
              "query": [
